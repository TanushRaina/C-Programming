#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int val;
    int pos = -1;
    int arr[100];
    
    for (int i = 0 ; i<n; i++) scanf("%d",&arr[i]);
    scanf("%d",&val);
    for(int i = 0; i<n; i++){
        if(val == arr[i]){
            
        
        pos = i; 
            break;
        }
    }
    if(pos != -1){
    for(int i = pos ; i< n - 1; i++) arr[i] = arr[i+1];
        n--;
      
    }
    for(int i = 0 ; i<n ; i++) printf("%d ",arr[i]);

    /* Enter your code here. Read input from STDIN. Print output to STDOUT */    
    return 0;
}
