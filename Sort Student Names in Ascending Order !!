#include<string.h>
#include<stdio.h>
int main(){
    int n;
    scanf("%d",&n);
    char str[101][101];
    char temp[101];
    for(int i = 0 ; i <n ; i++) scanf("%s",str[i]);
    for(int i = 0 ; i<n ; i++) {
        for(int j = i+1; j<n ;j++){
            if(strcmp(str[i],str[j])>0){
            strcpy(temp, str[i]);
            strcpy(str[i],str[j]);
            strcpy(str[j],temp);
        }
            
            }
    
    }
    for(int i =0 ; i <n ; i++) printf("%s\n",str[i]);
    return 0; 
}
