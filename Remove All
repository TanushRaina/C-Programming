#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>

int main() {
    int n;
    scanf("%d",&n);
    int list[n];
    for(int i=0;i<n;i++){
        scanf("%d",&list[i]);
    }
    int value;
    int k = 0 ; 
    scanf("%d",&value);
    for(int i = 0 ; i<n; i++){
        if(value != list[i]){
            list[k] = list[i];
            k++;
        }
    }
    for(int i=0;i<k;i++){
        printf("%d ",list[i]);
    }
    return 0;
}
